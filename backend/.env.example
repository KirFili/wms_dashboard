# WMS Dashboard — параметры подключения
DATABASE_URL=postgresql+asyncpg://wms_user:wms_password@localhost:5432/wms_dashboard
DATABASE_URL_SYNC=postgresql+psycopg2://wms_user:wms_password@localhost:5432/wms_dashboard

# JWT
SECRET_KEY=change-me-to-a-secure-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Приложение
APP_TITLE=WMS Dashboard
APP_VERSION=1.0.0
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Импорт
MAX_UPLOAD_SIZE_MB=20
UPLOAD_DIR=./uploads
